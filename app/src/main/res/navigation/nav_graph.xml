<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.myimagelogapp.fragment.SplashFragment"
        android:label="Splash">
        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.myimagelogapp.fragment.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.myimagelogapp.fragment.HomeFragment"
        android:label="Home">

        <action
            android:id="@+id/action_home_to_create"
            app:destination="@id/postCreateFragment" />

        <action
            android:id="@+id/action_home_to_uploadQueue"
            app:destination="@id/uploadQueueFragment" />

        <action
            android:id="@+id/action_home_to_post_detail"
            app:destination="@id/postDetailFragment" />

        <action
            android:id="@+id/action_home_to_praise"
            app:destination="@id/praiseFragment" />
    </fragment>

    <fragment
        android:id="@+id/praiseFragment"
        android:name="com.example.myimagelogapp.fragment.PraiseFragment"
        android:label="@string/praise_page_title" />

    <fragment
        android:id="@+id/postCreateFragment"
        android:name="com.example.myimagelogapp.fragment.PostCreateFragment"
        android:label="Create" />

    <fragment
        android:id="@+id/uploadQueueFragment"
        android:name="com.example.myimagelogapp.fragment.UploadQueueFragment"
        android:label="Uploads" />

    <fragment
        android:id="@+id/postDetailFragment"
        android:name="com.example.myimagelogapp.fragment.PostDetailFragment"
        android:label="글 보기">
        <argument
            android:name="imageId"
            app:argType="long"
            android:defaultValue="0L" />
        <argument
            android:name="imageUrl"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="dateText"
            app:argType="string"
            android:defaultValue="" />
    </fragment>
</navigation>